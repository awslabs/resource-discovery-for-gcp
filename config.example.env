# GCP Usage Discovery - Configuration File
# Copy this file to config.env and update with your values
# Usage: ./scripts/gcp_usage_discovery.sh -f config.env
#
# Note: CLI parameters always override config file values
# Example: ./scripts/gcp_usage_discovery.sh -f config.env -t "" (clears tags)
#
# Performance Tip: Run this script from Cloud Shell for best performance.
# Cloud Shell runs within Google's network, providing fast access to BigQuery
# and Cloud Storage. Ensure your BigQuery dataset and Cloud Storage bucket
# are in the same region when possible.

# Required Parameters
BILLING_TABLE="myproject.billing.gcp_export"    # Format: project.dataset.table
GCS_BUCKET="mybucket"                           # Without gs:// prefix, can include folder: mybucket/folder
CUSTOMER_NAME="acme"                            # Output file prefix (no spaces) - for naming only, does NOT filter data

# Optional Parameters
# CAPTURE_MONTH="202512"                        # YYYYMM format (defaults to prior month)
# CAPTURE_TAGS="environment,env"                # Comma-separated tags to capture (default: none)
# CAPTURE_LABELS="environment,env"              # Comma-separated labels to capture (default: none)
# PROJECT_FILTER="project1,project2"            # Comma-separated project IDs to filter (no spaces)

# Automation Options
# SKIP_CONFIRM="true"                           # Set to true to skip all confirmation prompts
# DRY_RUN="true"                                # Set to true to validate query and exit (useful for testing config changes)
# ANONYMIZE="true"                              # Set to true to hash sensitive identifiers (resourceName, resourceGlobalName, projectID)
                                                # WARNING: You will NOT be able to link pricing back to specific resources when anonymized

# Advanced Options (not supported by all downstream analysis tools)
# DATE_RANGE="31"                               # Days to extract (max 31, mutually exclusive with month)
# USE_STANDARD_EXPORT="true"                    # Set to true for standard export (no resource details)
